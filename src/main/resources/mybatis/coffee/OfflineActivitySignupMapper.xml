<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project.coffee.offlineActivity.mapper.OfflineActivitySignupMapper">

    <resultMap type="OfflineActivitySignup" id="OfflineActivitySignupResult">
        <result property="signupId" column="signup_id" />
        <result property="activityId" column="activity_id" />
        <result property="userId" column="user_id" />
        <result property="status" column="status" />
        <result property="signupTime" column="signup_time" />
        <result property="cancelTime" column="cancel_time" />
        <result property="checkinTime" column="checkin_time" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
        <result property="activityTitle" column="activity_title" />
        <result property="activityCoverImage" column="activity_cover_image" />
        <result property="activityStartTime" column="activity_start_time" />
        <result property="activityEndTime" column="activity_end_time" />
        <result property="activityLocation" column="activity_location" />
        <result property="nickname" column="nickname" />
        <result property="avatar" column="avatar" />
    </resultMap>

    <sql id="selectSignupJoinVo">
        select s.signup_id, s.activity_id, s.user_id, s.status, s.signup_time, s.cancel_time, s.checkin_time,
               s.create_time, s.update_time, s.remark,
               a.title as activity_title, a.cover_image as activity_cover_image,
               a.start_time as activity_start_time, a.end_time as activity_end_time, a.location as activity_location,
               u.nickname, u.avatar
        from t_offline_activity_signup s
        left join t_offline_activity a on a.activity_id = s.activity_id
        left join t_wxuser u on u.id = s.user_id
    </sql>

    <select id="selectOfflineActivitySignupBySignupId" parameterType="Long" resultMap="OfflineActivitySignupResult">
        <include refid="selectSignupJoinVo"/>
        where s.signup_id = #{signupId}
    </select>

    <select id="selectUserSignup" resultMap="OfflineActivitySignupResult">
        <include refid="selectSignupJoinVo"/>
        where s.activity_id = #{activityId}
          and s.user_id = #{userId}
        order by s.signup_id desc
        limit 1
    </select>

    <select id="selectOfflineActivitySignupList" parameterType="OfflineActivitySignup" resultMap="OfflineActivitySignupResult">
        <include refid="selectSignupJoinVo"/>
        <where>
            <if test="activityId != null"> and s.activity_id = #{activityId}</if>
            <if test="userId != null"> and s.user_id = #{userId}</if>
            <if test="status != null"> and s.status = #{status}</if>
        </where>
        order by s.signup_time desc, s.signup_id desc
    </select>

    <select id="selectUserSignupList" parameterType="Long" resultMap="OfflineActivitySignupResult">
        <include refid="selectSignupJoinVo"/>
        where s.user_id = #{userId}
        order by s.signup_time desc, s.signup_id desc
    </select>

    <select id="countReservedByActivityId" parameterType="Long" resultType="int">
        select count(1)
        from t_offline_activity_signup
        where activity_id = #{activityId}
          and status in (0, 2)
    </select>

    <insert id="insertOfflineActivitySignup" parameterType="OfflineActivitySignup" useGeneratedKeys="true" keyProperty="signupId">
        insert into t_offline_activity_signup
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="activityId != null">activity_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="status != null">status,</if>
            <if test="signupTime != null">signup_time,</if>
            <if test="cancelTime != null">cancel_time,</if>
            <if test="checkinTime != null">checkin_time,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="activityId != null">#{activityId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="status != null">#{status},</if>
            <if test="signupTime != null">#{signupTime},</if>
            <if test="cancelTime != null">#{cancelTime},</if>
            <if test="checkinTime != null">#{checkinTime},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateOfflineActivitySignup" parameterType="OfflineActivitySignup">
        update t_offline_activity_signup
        <trim prefix="SET" suffixOverrides=",">
            <if test="activityId != null">activity_id = #{activityId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="signupTime != null">signup_time = #{signupTime},</if>
            cancel_time = #{cancelTime},
            checkin_time = #{checkinTime},
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where signup_id = #{signupId}
    </update>

    <delete id="deleteOfflineActivitySignupByActivityId" parameterType="Long">
        delete from t_offline_activity_signup where activity_id = #{activityId}
    </delete>

    <delete id="deleteOfflineActivitySignupByActivityIds" parameterType="String">
        delete from t_offline_activity_signup where activity_id in
        <foreach item="activityId" collection="array" open="(" separator="," close=")">
            #{activityId}
        </foreach>
    </delete>

    <update id="markSignupStatus">
        update t_offline_activity_signup
        set status = #{status},
            checkin_time = now(),
            update_time = now()
        where signup_id = #{signupId}
          and status = 0
    </update>
</mapper>
