<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project.coffee.scanOrder.mapper.ScanProductMapper">

    <resultMap type="ScanProduct" id="ScanProductResult">
        <result property="productId"   column="product_id"   />
        <result property="categoryId"  column="category_id"  />
        <result property="productName" column="product_name" />
        <result property="subTitle"    column="sub_title"    />
        <result property="imageUrl"    column="image_url"    />
        <result property="videoUrl"    column="video_url"    />
        <result property="price"       column="price"        />
        <result property="monthSales"  column="month_sales"  />
        <result property="tag"         column="tag"          />
        <result property="status"      column="status"       />
        <result property="sortOrder"   column="sort_order"   />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"  column="create_time"  />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"  column="update_time"  />
        <result property="remark"      column="remark"       />
    </resultMap>

    <sql id="selectScanProductVo">
        select product_id, category_id, product_name, sub_title, image_url, video_url, price,
               month_sales, tag, status, sort_order,
               create_by, create_time, update_by, update_time, remark
        from t_scan_product
    </sql>

    <select id="selectScanProductById" parameterType="Long" resultMap="ScanProductResult">
        <include refid="selectScanProductVo"/>
        where product_id = #{productId}
    </select>

    <select id="selectScanProductList" parameterType="ScanProduct" resultMap="ScanProductResult">
        <include refid="selectScanProductVo"/>
        <where>
            <if test="categoryId != null"> and category_id = #{categoryId}</if>
            <if test="productName != null and productName != ''">
                and product_name like concat('%', #{productName}, '%')
            </if>
            <if test="status != null"> and status = #{status}</if>
        </where>
        order by
        case when sort_order is null then 1 else 0 end,
        sort_order asc,
        product_id asc
    </select>

    <select id="countScanProductByCategoryIds" parameterType="String" resultType="int">
        select count(1)
        from t_scan_product
        where category_id in
        <foreach collection="array" item="categoryId" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
    </select>

    <insert id="insertScanProduct" parameterType="ScanProduct" useGeneratedKeys="true" keyProperty="productId">
        insert into t_scan_product
        <trim prefix="(" suffix=")" suffixOverrides=",">
            category_id,
            product_name,
            <if test="subTitle != null">sub_title,</if>
            <if test="imageUrl != null">image_url,</if>
            <if test="videoUrl != null">video_url,</if>
            price,
            <if test="monthSales != null">month_sales,</if>
            <if test="tag != null">tag,</if>
            <if test="status != null">status,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            #{categoryId},
            #{productName},
            <if test="subTitle != null">#{subTitle},</if>
            <if test="imageUrl != null">#{imageUrl},</if>
            <if test="videoUrl != null">#{videoUrl},</if>
            #{price},
            <if test="monthSales != null">#{monthSales},</if>
            <if test="tag != null">#{tag},</if>
            <if test="status != null">#{status},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateScanProduct" parameterType="ScanProduct">
        update t_scan_product
        <trim prefix="SET" suffixOverrides=",">
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="productName != null and productName != ''">product_name = #{productName},</if>
            <if test="subTitle != null">sub_title = #{subTitle},</if>
            <if test="imageUrl != null">image_url = #{imageUrl},</if>
            <if test="videoUrl != null">video_url = #{videoUrl},</if>
            <if test="price != null">price = #{price},</if>
            <if test="monthSales != null">month_sales = #{monthSales},</if>
            <if test="tag != null">tag = #{tag},</if>
            <if test="status != null">status = #{status},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where product_id = #{productId}
    </update>

    <delete id="deleteScanProductByIds" parameterType="String">
        delete from t_scan_product where product_id in
        <foreach collection="array" item="productId" open="(" separator="," close=")">
            #{productId}
        </foreach>
    </delete>

</mapper>
