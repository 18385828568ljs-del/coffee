<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project.coffee.product.mapper.TProductMapper">
    
    <resultMap type="TProduct" id="TProductResult">
        <result property="productId"    column="product_id"    />
        <result property="categoryId"    column="category_id"    />
        <result property="productName"    column="product_name"    />
        <result property="origin"    column="origin"    />
        <result property="processingMethod"    column="processing_method"    />
        <result property="roastLevel"    column="roast_level"    />
        <result property="flavorNotes"    column="flavor_notes"    />
        <result property="description"    column="description"    />
        <result property="price"    column="price"    />
        <result property="stock"    column="stock"    />
        <result property="imageUrl"    column="image_url"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTProductVo">
        select product_id, category_id, product_name, origin, processing_method, roast_level, flavor_notes, description, price, stock, image_url, status, create_by, create_time, update_by, update_time, remark from t_product
    </sql>

    <select id="selectTProductList" parameterType="TProduct" resultMap="TProductResult">
        <include refid="selectTProductVo"/>
        <where>  
            <if test="categoryId != null "> and category_id = #{categoryId}</if>
            <if test="productName != null  and productName != ''"> and product_name like concat('%', #{productName}, '%')</if>
            <if test="origin != null  and origin != ''"> and origin = #{origin}</if>
            <if test="processingMethod != null  and processingMethod != ''"> and processing_method = #{processingMethod}</if>
            <if test="roastLevel != null  and roastLevel != ''"> and roast_level = #{roastLevel}</if>
            <if test="flavorNotes != null  and flavorNotes != ''"> and flavor_notes = #{flavorNotes}</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="price != null "> and price = #{price}</if>
            <if test="stock != null "> and stock = #{stock}</if>
            <if test="imageUrl != null  and imageUrl != ''"> and image_url = #{imageUrl}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
        order by
        case when create_time is null then 1 else 0 end,
        create_time desc,
        product_id desc
    </select>

    <select id="countProductByCategoryIds" resultType="int">
        select count(1)
        from t_product
        where category_id in
        <foreach item="categoryId" collection="array" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
    </select>
    
    <select id="selectTProductByProductId" parameterType="Long" resultMap="TProductResult">
        <include refid="selectTProductVo"/>
        where product_id = #{productId}
    </select>
        
    <insert id="insertTProduct" parameterType="TProduct" useGeneratedKeys="true" keyProperty="productId">
        insert into t_product
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">category_id,</if>
            <if test="productName != null and productName != ''">product_name,</if>
            <if test="origin != null">origin,</if>
            <if test="processingMethod != null">processing_method,</if>
            <if test="roastLevel != null">roast_level,</if>
            <if test="flavorNotes != null">flavor_notes,</if>
            <if test="description != null">description,</if>
            <if test="price != null">price,</if>
            <if test="stock != null">stock,</if>
            <if test="imageUrl != null">image_url,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">#{categoryId},</if>
            <if test="productName != null and productName != ''">#{productName},</if>
            <if test="origin != null">#{origin},</if>
            <if test="processingMethod != null">#{processingMethod},</if>
            <if test="roastLevel != null">#{roastLevel},</if>
            <if test="flavorNotes != null">#{flavorNotes},</if>
            <if test="description != null">#{description},</if>
            <if test="price != null">#{price},</if>
            <if test="stock != null">#{stock},</if>
            <if test="imageUrl != null">#{imageUrl},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateTProduct" parameterType="TProduct">
        update t_product
        <trim prefix="SET" suffixOverrides=",">
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="productName != null and productName != ''">product_name = #{productName},</if>
            <if test="origin != null">origin = #{origin},</if>
            <if test="processingMethod != null">processing_method = #{processingMethod},</if>
            <if test="roastLevel != null">roast_level = #{roastLevel},</if>
            <if test="flavorNotes != null">flavor_notes = #{flavorNotes},</if>
            <if test="description != null">description = #{description},</if>
            <if test="price != null">price = #{price},</if>
            <if test="stock != null">stock = #{stock},</if>
            <if test="imageUrl != null">image_url = #{imageUrl},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where product_id = #{productId}
    </update>

    <update id="decreaseStock">
        update t_product
        set stock = stock - #{quantity},
            update_time = now()
        where product_id = #{productId}
          and status = 1
          and stock is not null
          and stock >= #{quantity}
          and stock > 0
    </update>

    <update id="increaseStock">
        update t_product
        set stock = stock + #{quantity},
            update_time = now()
        where product_id = #{productId}
          and stock is not null
    </update>

    <select id="selectTProductByProductIds" parameterType="java.util.List" resultMap="TProductResult">
        <include refid="selectTProductVo"/>
        where product_id in
        <foreach item="productId" collection="productIds" open="(" separator="," close=")">
            #{productId}
        </foreach>
    </select>

    <delete id="deleteTProductByProductId" parameterType="Long">
        delete from t_product where product_id = #{productId}
    </delete>

    <delete id="deleteTProductByProductIds" parameterType="String">
        delete from t_product where product_id in 
        <foreach item="productId" collection="array" open="(" separator="," close=")">
            #{productId}
        </foreach>
    </delete>

</mapper>
