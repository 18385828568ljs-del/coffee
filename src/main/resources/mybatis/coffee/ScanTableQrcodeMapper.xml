<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project.coffee.scanOrder.mapper.ScanTableQrcodeMapper">

    <resultMap type="ScanTableQrcode" id="ScanTableQrcodeResult">
        <result property="tableId"    column="table_id"    />
        <result property="shopId"     column="shop_id"     />
        <result property="shopName"   column="shop_name"   />
        <result property="tableNo"    column="table_no"    />
        <result property="scene"      column="scene"       />
        <result property="qrUrl"      column="qr_url"      />
        <result property="status"     column="status"      />
        <result property="createBy"   column="create_by"   />
        <result property="createTime" column="create_time" />
        <result property="updateBy"   column="update_by"   />
        <result property="updateTime" column="update_time" />
        <result property="remark"     column="remark"      />
    </resultMap>

    <sql id="selectScanTableQrcodeVo">
        select table_id, shop_id, shop_name, table_no, scene, qr_url, status,
               create_by, create_time, update_by, update_time, remark
        from t_scan_table_qrcode
    </sql>

    <select id="selectByShopAndTable" parameterType="ScanTableQrcode" resultMap="ScanTableQrcodeResult">
        <include refid="selectScanTableQrcodeVo"/>
        <where>
            <if test="shopId != null">  and shop_id = #{shopId}</if>
            <if test="tableNo != null and tableNo != ''"> and table_no = #{tableNo}</if>
        </where>
        limit 1
    </select>

    <select id="selectById" parameterType="Long" resultMap="ScanTableQrcodeResult">
        <include refid="selectScanTableQrcodeVo"/>
        where table_id = #{tableId}
    </select>

    <select id="selectList" parameterType="ScanTableQrcode" resultMap="ScanTableQrcodeResult">
        <include refid="selectScanTableQrcodeVo"/>
        <where>
            <if test="shopId != null"> and shop_id = #{shopId}</if>
            <if test="tableNo != null and tableNo != ''"> and table_no like concat('%', #{tableNo}, '%')</if>
            <if test="status != null"> and status = #{status}</if>
            <if test="scene != null and scene != ''"> and scene = #{scene}</if>
        </where>
        order by shop_id asc, table_no asc, table_id asc
    </select>

    <insert id="insert" parameterType="ScanTableQrcode" useGeneratedKeys="true" keyProperty="tableId">
        insert into t_scan_table_qrcode
        <trim prefix="(" suffix=")" suffixOverrides=",">
            shop_id,
            <if test="shopName != null">shop_name,</if>
            table_no,
            <if test="scene != null and scene != ''">scene,</if>
            <if test="qrUrl != null">qr_url,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            #{shopId},
            <if test="shopName != null">#{shopName},</if>
            #{tableNo},
            <if test="scene != null and scene != ''">#{scene},</if>
            <if test="qrUrl != null">#{qrUrl},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="update" parameterType="ScanTableQrcode">
        update t_scan_table_qrcode
        <trim prefix="SET" suffixOverrides=",">
            <if test="shopId != null">shop_id = #{shopId},</if>
            <if test="shopName != null">shop_name = #{shopName},</if>
            <if test="tableNo != null and tableNo != ''">table_no = #{tableNo},</if>
            <if test="scene != null and scene != ''">scene = #{scene},</if>
            <if test="qrUrl != null">qr_url = #{qrUrl},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where table_id = #{tableId}
    </update>

    <delete id="deleteById" parameterType="Long">
        delete from t_scan_table_qrcode where table_id = #{tableId}
    </delete>

</mapper>
