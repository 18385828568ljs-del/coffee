{
	"easycom": {
		"^u-(.*)": "@/uni_modules/uview-ui/components/u-$1/u-$1.vue",
		"^app-nav$": "@/components/app-nav.vue",
		"^bottom-tab-bar$": "@/components/bottom-tab-bar.vue"
	},
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "咖啡商城",
				"enablePullDownRefresh": true,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/product/detail",
			"style": {
				"navigationBarTitleText": "商品详情",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/mall/index",
			"style": {
				"navigationBarTitleText": "咖啡豆与周边",
				"enablePullDownRefresh": true,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/cart/cart",
			"style": {
				"navigationBarTitleText": "购物车",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/order/list",
			"style": {
				"navigationBarTitleText": "我的订单",
				"enablePullDownRefresh": true,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/order/detail",
			"style": {
				"navigationBarTitleText": "订单详情",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/order/confirm",
			"style": {
				"navigationBarTitleText": "确认订单",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/me/me",
			"style": {
				"navigationBarTitleText": "我的",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/me/settings",
			"style": {
				"navigationBarTitleText": "设置",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/me/about",
			"style": {
				"navigationBarTitleText": "店铺说明",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/address/list",
			"style": {
				"navigationBarTitleText": "收货地址",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/address/edit",
			"style": {
				"navigationBarTitleText": "编辑地址",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/wallet/recharge",
			"style": {
				"navigationBarTitleText": "充值中心",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/wallet/log",
			"style": {
				"navigationBarTitleText": "余额明细",
				"enablePullDownRefresh": true,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/scan/menu",
			"style": {
				"navigationBarTitleText": "扫码点单",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/scan/confirm",
			"style": {
				"navigationBarTitleText": "确认点单",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/scan/pay-success",
			"style": {
				"navigationBarTitleText": "付款成功",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		}
	],
	"tabBar": {
		"custom": true,
		"list": [
			{
				"pagePath": "pages/index/index"
			},
			{
				"pagePath": "pages/scan/menu"
			},
			{
				"pagePath": "pages/cart/cart"
			},
			{
				"pagePath": "pages/me/me"
			}
		]
	},
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "咖啡商城",
		"navigationBarBackgroundColor": "#FFFFFF",
		"backgroundColor": "#FFFFFF"
	}
}
